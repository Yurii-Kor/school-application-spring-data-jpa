@startuml
allowmixing

title School Application Spring Data JPA - Application Structure Overview

skinparam shadowing false
skinparam linetype ortho
skinparam packageStyle rectangle
skinparam rectangle {
  RoundCorner 12
}
hide stereotype

top to bottom direction

rectangle "Spring Boot Entry Point\n\nSchoolApplicationConsole\n\nStarts the application\nand creates the Spring context" as app

rectangle "Console UI\n\nMainMenu\nMenuActions\n\nReads user input and delegates\nselected menu actions" as ui

rectangle "Service Layer\n\nViewDaoService\nEntityValidationService\nInputPreprocessingService\n\nCoordinates console actions,\nvalidation, preprocessing,\nand persistence operations" as service

rectangle "Spring Data Repository Layer\n\nStudentRepository\nCourseRepository\nGroupRepository\n\nDefines repository interfaces\nfor entity persistence\nand query operations" as repositories

rectangle "Spring Data JPA Infrastructure\n\nJpaRepository\nRepository proxies\nQuery methods\nCustom @Query methods\nTransactions\n\nCreates repository implementations\nand delegates persistence work\nto JPA/Hibernate" as springdata

rectangle "Hibernate / JPA Infrastructure\n\nEntityManager\nPersistence Context\nORM mapping\nSQL generation\n\nManages entity state,\nrelationships, and database\nsynchronization" as jpa

rectangle "JPA Entity Model\n\nStudent\nGroup\nCourse\n\nMaps Java objects to\nrelational database tables" as domain

rectangle "Entity Relationships\n\nGroup 1 → many Students\nStudent many ↔ many Courses\n\nRepresented through\nJPA annotations" as relations

rectangle "Configuration\n\nSpring Boot properties\nFlyway migrations\nBean Validation\nDocker Compose support\n\nProvides datasource,\nschema setup, validation,\nand runtime configuration" as config

database "PostgreSQL\n\nTables:\ngroups\nstudents\ncourses\nstudents_courses" as db

app --> ui : starts
ui --> service : delegates commands
service --> repositories : calls repository methods
repositories --> springdata : implemented by Spring Data
springdata --> jpa : delegates persistence
jpa --> db : SQL generated by Hibernate
repositories --> domain : works with entities
domain --> relations : defines mappings
config --> springdata : configures repositories
config --> jpa : configures JPA and datasource

note left of repositories
This project replaces manual DAO classes
with Spring Data JPA repository interfaces.

The application code calls repository methods,
while Spring Data creates implementations
and delegates persistence to JPA/Hibernate.
end note

@enduml
